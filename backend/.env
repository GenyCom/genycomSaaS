# → https://myaccount.google.com/apppasswords
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=genycomc@gmail.com
MAIL_PASSWORD="kfli ytyp hdsc ccol"
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=genycomc@gmail.com
MAIL_FROM_NAME="GenyCom Monitoring"

# ─── Monitoring des Exceptions ───
EXCEPTION_MAIL_ENABLED=true
